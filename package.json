  "dependencies": {
    "@types/node": "^25.5.0",
    "execa": "^9.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
